# Firebase Configuration
# Viteでは VITE_ プレフィックスを使用してクライアントに公開します
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Firebase Cloud Functions URL
VITE_FIREBASE_FUNCTIONS_URL=https://us-central1-your-project-id.cloudfunctions.net/api

# Google Custom Search API Configuration (Deprecated - サービス終了予定 2027年1月)
# VITE_GOOGLE_CUSTOM_SEARCH_API_KEY=your-google-custom-search-api-key
# VITE_GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your-search-engine-id

# Brave Search API Configuration (サーバーサイドで使用)
BRAVE_SEARCH_API_KEY=your-brave-api-key

# Development settings
VITE_USE_EMULATOR=false
