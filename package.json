{
  "name": "firebase-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "pnpm -F \"web\"",
    "functions": "pnpm -F \"functions\"",
    "common": "pnpm -F \"common\"",
    "dev": "turbo run dev --no-cache --parallel --continue",
    "build": "pnpm --filter @lgtmonk/web run build",
    "start": "pnpm --filter @lgtmonk/web run start",
    "build:turbo": "turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "clean": "turbo run clean && rimraf node_modules",
    "check": "biome check ./apps/*/src/**/* ./packages/*/src/**/*",
    "format": "biome format --write ./apps/*/src/**/* ./packages/*/src/**/*",
    "cspell": "cspell -c ./cspell.json './apps/*/src/**/*' './packages/*/src/**/*'",
    "prepare": "husky",
    "env:encrypt": "pnpm -F web run env:encrypt && pnpm -F functions run env:encrypt && pnpm -F extension run env:encrypt",
    "env:decrypt": "pnpm -F web run env:decrypt && pnpm -F functions run env:decrypt && pnpm -F extension run env:decrypt"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "cspell": "^9.1.3",
    "husky": "^9.1.7",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": "22",
    "pnpm": ">=6.0.0"
  }
}
